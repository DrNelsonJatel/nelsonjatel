---
import Base from '../layouts/Base.astro';
import Testimonials from '../components/Testimonials.astro';
import { SITE, SPEAKER_REEL } from '../consts';

const topics = [
  { title: 'What Does Your Network Actually Look Like?', body: 'The hidden map of influence inside any board or organisation, and why the official structure rarely matches it.', href: '/publications', proof: 'Drawn from my published SNA research' },
  { title: 'Tracing the Signal', body: 'How to find what matters in a noisy organisation, and how to tell a real pattern from a story you wanted to be true.', href: '/tools', proof: 'See the tools that do this' },
  { title: 'The Hidden Architecture of Water Governance', body: 'Social network analysis applied to who actually decides when water, land, and competing interests meet. Drawn from a fifty-year study of one region.', href: '/publications', proof: 'Built on a fifty-year study' },
  { title: 'Weak Ties, Strong Decisions', body: 'Why the informal connections between people, the ones no policy accounts for, so often drive or stall the formal outcome.', href: '/publications', proof: 'Grounded in network research' },
];
const formats = ['Keynote (30 to 60 minutes)', 'Half-day workshop', 'Board or leadership working session'];

const speakingLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Keynote speaking',
  name: 'Keynote speaking, workshops, and board sessions',
  description: 'Keynotes, workshops, and board sessions on social network analysis and the networks that shape how organisations decide, in water, in governance, and anywhere people and power connect.',
  provider: { '@type': 'Person', name: 'Dr. Nelson Jatel', url: SITE.url },
  areaServed: 'Worldwide',
  audience: { '@type': 'Audience', audienceType: 'Conferences, boards, and leadership teams' },
};
---
<Base title="Book Nelson to speak" description="Keynotes, workshops, and board sessions on the networks that shape how organisations decide. Specific, evidence-led, built for your room.">
  <section class="section">
    <div class="wrap speaking-intro">
      <div class="stack-lg">
        <p class="eyebrow">Keynotes · Workshops · Board sessions</p>
        <h1>The room already has a network. I help you see it.</h1>
        <p class="hero-sub">
          Every board, every leadership team, every conference room runs on relationships
          that no org chart shows. I use social network analysis to make them visible: who
          actually decides, where influence concentrates, and where a network is brittle
          enough to fail under pressure. You leave with a clearer picture of how your
          organisation really works, and a few specific things to do about it.
        </p>
      </div>
      <img class="speaking-photo" src="/images/nelson-jatel.jpg" alt="Dr. Nelson Jatel speaking on water governance and networks" width="1000" height="799" loading="eager" />
    </div>
  </section>

  <section class="section topics-section">
    <div class="wrap">
      <h2>Keynote topics</h2>
      <div class="topics">
        {topics.map((t) => (
          <div class="topic">
            <h3>{t.title}</h3>
            <p class="muted">{t.body}</p>
            <a class="topic-proof" href={t.href}>{t.proof} →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap two-col">
      <div class="stack">
        <h2>Formats</h2>
        <ul class="plain">{formats.map((f) => <li>{f}</li>)}</ul>
      </div>
      <div class="stack">
        <h2>What you get</h2>
        <p class="muted measure">
          Not just a talk. Depending on the format, you can leave with a map of your own
          decision network, a read on where influence is concentrated, and a short list
          of the relationships worth strengthening before they are tested.
        </p>
      </div>
    </div>
  </section>

  {SPEAKER_REEL && (
    <section class="section">
      <div class="wrap stack">
        <p class="eyebrow">See me present</p>
        <div class="reel">
          <iframe src={`https://www.youtube-nocookie.com/embed/${SPEAKER_REEL}`} title="Dr. Nelson Jatel speaker reel"
            loading="lazy" referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        </div>
      </div>
    </section>
  )}

  <Testimonials />

  <section class="section fees-section">
    <div class="wrap two-col">
      <div class="stack">
        <h2>Fees</h2>
        <p class="muted measure">
          Fees vary by event, format, and location. Use the form below and I will come
          back with a number quickly.
        </p>
      </div>
      <div class="stack">
        <h2>Speaker kit</h2>
        <p class="muted measure">
          Topics, formats, a short bio, a photo, and where I have spoken, ready to drop into your programme.
        </p>
        <div class="kit-links">
          <a class="btn btn--ghost" href="/Nelson_Jatel_Speaker_Kit.pdf" target="_blank" rel="noopener">Download the speaker kit (PDF)</a>
          <a class="kit-view" href="/speaker-kit">View online →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section book-section" id="book">
    <div class="wrap">
      <p class="eyebrow">Invite Nelson to speak</p>
      <h2>Tell me about your event</h2>
      <p class="muted measure">I read every enquiry personally and reply within two business days.</p>

      <form class="book-form" data-enquiry data-kind="booking" novalidate>
        <p class="hp" aria-hidden="true">
          <label>Leave this empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
        </p>

        <div class="field">
          <label for="name">Your name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="org">Organisation</label>
          <input id="org" name="organisation" type="text" autocomplete="organization" />
        </div>
        <div class="field">
          <label for="date">Event date</label>
          <input id="date" name="event_date" type="text" placeholder="Date or rough timeframe" />
        </div>
        <div class="field">
          <label for="audience">Audience size (optional)</label>
          <input id="audience" name="audience_size" type="text" autocomplete="off" />
        </div>
        <div class="field">
          <label for="budget">Budget range (optional)</label>
          <input id="budget" name="budget" type="text" autocomplete="off" />
        </div>
        <div class="field">
          <label for="detail">What you are looking for</label>
          <textarea id="detail" name="detail" placeholder="Topic, format, anything else I should know"></textarea>
        </div>
        <button class="btn btn--primary" type="submit">Send enquiry</button>
        <p class="form-status fine" data-status aria-live="polite"></p>
        <p class="fine form-note">Or email me directly at {SITE.email}.</p>
      </form>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(speakingLd)} />
</Base>

<style>
  .hero-sub{ color:var(--slate); font-size:1.2rem; }
  .speaking-intro{ display:grid; grid-template-columns:1.5fr 1fr; gap:2.5rem; align-items:start; }
  .speaking-photo{ width:100%; height:auto; border-radius:4px; border:1px solid var(--hairline); }
  .reel{ position:relative; aspect-ratio:16/9; max-width:48rem; border:1px solid var(--hairline); border-radius:3px; overflow:hidden; margin-top:1rem; }
  .reel iframe{ position:absolute; inset:0; width:100%; height:100%; border:0; }
  .topics{ display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin-top:1.5rem; }
  .topic{ padding:1.5rem; border:1px solid var(--hairline); border-radius:3px; background:var(--ground-soft); }
  .topic h3{ font-size:1.3rem; }
  .topic p{ margin-top:0.6rem; }
  .topic-proof{ display:inline-block; margin-top:0.85rem; color:var(--signal); font-size:0.85rem; font-weight:600; }
  .topic-proof:hover{ color:var(--signal-hi); }
  .kit-links{ display:flex; align-items:center; gap:1.25rem; flex-wrap:wrap; }
  .kit-view{ color:var(--signal); font-weight:600; font-size:0.9rem; }
  .two-col{ display:grid; grid-template-columns:1fr 1fr; gap:2.5rem; }
  .plain{ list-style:none; padding:0; }
  .plain li{ padding:0.5rem 0; border-bottom:1px solid var(--hairline); color:var(--slate); font-family:var(--font-mono); font-size:0.9rem; }
  .book-section{ border-top:1px solid var(--hairline); }
  .book-form{ max-width:34rem; margin-top:1.5rem; }
  .form-note{ margin-top:1rem; }
  .hp{ position:absolute; left:-9999px; }
  .form-status{ min-height:1.2em; margin-top:0.6rem; }
  .form-status[data-kind="error"]{ color:#e88a8a; }
  .form-status[data-kind="ok"]{ color:var(--ink); }
  @media (max-width:767px){ .topics, .two-col, .speaking-intro{ grid-template-columns:1fr; } .speaking-photo{ max-width:360px; } }
</style>

<script>
  import { initEnquiryForms } from '../scripts/enquiry';
  initEnquiryForms();
</script>
