---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { CLOSER, SITE, NEWSLETTER } from '../../consts';

export async function getStaticPaths() {
  const all = await getCollection('newsletter');
  const issues = all.filter((e) => (import.meta.env.PROD ? !e.data.draft : true));
  return issues.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, issue, dek, pubDate } = entry.data;

const fmt = (d: Date) => d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: dek,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  publisher: { '@type': 'Person', name: SITE.author },
  isPartOf: { '@type': 'CreativeWorkSeries', name: NEWSLETTER.name },
};
---
<Base title={title} description={dek}>
  <article class="section">
    <div class="wrap stack-lg">
      <p class="eyebrow"><a href="/newsletter">{NEWSLETTER.name}</a> · Issue {issue} · {fmt(pubDate)}</p>
      <h1>{title}</h1>
      <p class="dek">{dek}</p>

      <div class="prose">
        <Content />
      </div>

      <p class="closer-line">{CLOSER}</p>

      <hr class="trace" />
      <NewsletterForm />
      <p class="back"><a href="/newsletter">← All editions</a></p>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
</Base>

<style>
  .dek{ font-family:var(--font-display); font-size:1.4rem; line-height:1.3; color:var(--slate); max-width:40ch; }
  .prose{ max-width:38rem; }
  .prose :global(p){ color:var(--ink); margin-block:1.1rem; line-height:1.7; }
  .prose :global(h2){ margin-top:2.25rem; font-size:1.45rem; font-family:var(--font-display); color:var(--ink); }
  .prose :global(strong){ color:var(--ink); }
  .closer-line{ font-family:var(--font-display); font-style:italic; color:var(--slate); font-size:1.15rem; }
  .back a{ color:var(--signal); }
</style>
