---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const all = await getCollection('episodes');
const episodes = all
  .filter((e) => import.meta.env.PROD ? !e.data.draft : true)
  .sort((a, b) => b.data.episode - a.data.episode);
---
<Base title="Weekly shorts" description="Short videos on the hidden networks behind how decisions get made and how change happens. One idea at a time, with a full transcript on every clip.">
  <section class="section">
    <div class="wrap stack-lg">
      <p class="eyebrow">The Signal · Weak Ties · weekly shorts</p>
      <h1>Weekly shorts</h1>
      <p class="measure intro">
        Short videos on the hidden networks behind how decisions get made and how change
        happens. One idea at a time, for people who would rather think than scroll. New
        clips most weeks. Every one has a full transcript, because an idea you cannot
        search is an idea that disappears.
      </p>
    </div>
  </section>

  {episodes.length > 0 ? (
    <section class="section">
      <div class="wrap">
        <div class="grid">
          {episodes.map((e) => (
            <EpisodeCard
              href={`/signals/${e.id}/`}
              episode={e.data.episode}
              category={e.data.category}
              title={e.data.title}
              summary={e.data.summary}
            />
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="wrap"><NewsletterForm /></div>
    </section>
  )}
</Base>

<style>
  .intro{ color:var(--slate); font-size:1.15rem; }
  .grid{ display:grid; grid-template-columns:repeat(auto-fill, minmax(20rem, 1fr)); gap:1.5rem; }
</style>
