---
import { NEWSLETTER_ACTION, NEWSLETTER_PROOF } from '../consts';
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
// No live placeholder: the form only renders once an ESP action is configured.
const enabled = NEWSLETTER_ACTION.length > 0;
---
{enabled && (
  <div class:list={['nl', { compact }]}>
    <p class="eyebrow">Signals in the Stream · a weekly short</p>
    <p class="nl-prompt">One sharp idea on water and networks, most weeks. No noise.</p>
    <form class="nl-form" action={NEWSLETTER_ACTION} method="post">
      <label class="visually-hidden" for="nl-email">Email address</label>
      <input id="nl-email" type="email" name="email" required
             autocomplete="email" placeholder="you@example.com" />
      <button class="btn btn--primary" type="submit">Subscribe</button>
    </form>
    {NEWSLETTER_PROOF && <p class="fine nl-proof">Join {NEWSLETTER_PROOF} readers who trace the signal.</p>}
  </div>
)}

<style>
  .nl-prompt{ color:var(--slate); margin-top:0.35rem; }
  .nl-form{ display:flex; gap:0.6rem; flex-wrap:wrap; margin-top:0.9rem; max-width:30rem; }
  .nl-form input{
    flex:1 1 14rem; background:var(--ground-soft); border:1px solid var(--hairline);
    color:var(--ink); font:inherit; padding:0.7em 0.85em; border-radius:2px;
  }
  .nl-form input:focus{ border-color:var(--signal); outline:none; }
  .nl-proof{ margin-top:0.6rem; }
  .visually-hidden{
    position:absolute; width:1px; height:1px; padding:0; margin:-1px;
    overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0;
  }
</style>
