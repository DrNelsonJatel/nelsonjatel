---
import { TESTIMONIALS } from '../consts';
// Renders nothing until real, attributable quotes exist (no fabricated proof).
---
{TESTIMONIALS.length > 0 && (
  <section class="section">
    <div class="wrap">
      <div class="quotes">
        {TESTIMONIALS.map((t) => (
          <figure class="quote">
            <blockquote>{t.quote}</blockquote>
            <figcaption class="mono">{t.name} · {t.role}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .quotes{ display:grid; gap:2rem; grid-template-columns:repeat(auto-fit, minmax(20rem, 1fr)); }
  .quote blockquote{
    font-family:var(--font-display); font-size:1.5rem; line-height:1.3; color:var(--ink);
  }
  .quote figcaption{ margin-top:1rem; color:var(--slate); font-size:0.8125rem; letter-spacing:0.04em; }
</style>
