---
// The signature: a single amber line traced out of a cool node-field.
// Draws on once; respects prefers-reduced-motion. Decorative (aria-hidden);
// the meaning lives in the adjacent headline.
---
<div class="hero-signal" aria-hidden="true">
  <svg viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid meet" focusable="false">
    <defs>
      <filter id="njGlow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="b" />
        <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
      </filter>
      <linearGradient id="njLine" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#F3B24E" stop-opacity="0.6" />
        <stop offset="0.5" stop-color="#F3B24E" />
        <stop offset="1" stop-color="#FFD27A" />
      </linearGradient>
    </defs>

    <g class="scatter" fill="#4A6E7C">
      <circle cx="95" cy="110" r="2.0" opacity="0.30" /><circle cx="130" cy="160" r="1.4" opacity="0.22" />
      <circle cx="150" cy="85" r="2.6" opacity="0.28" /><circle cx="185" cy="140" r="1.6" opacity="0.20" />
      <circle cx="210" cy="195" r="2.2" opacity="0.26" /><circle cx="240" cy="100" r="1.3" opacity="0.18" />
      <circle cx="270" cy="175" r="2.4" opacity="0.24" /><circle cx="300" cy="130" r="1.5" opacity="0.20" />
      <circle cx="120" cy="215" r="1.8" opacity="0.22" /><circle cx="175" cy="235" r="2.1" opacity="0.25" />
      <circle cx="345" cy="85" r="1.4" opacity="0.18" /><circle cx="390" cy="155" r="2.0" opacity="0.22" />
      <circle cx="430" cy="110" r="1.5" opacity="0.18" /><circle cx="500" cy="150" r="1.7" opacity="0.20" />
      <circle cx="560" cy="95" r="1.3" opacity="0.16" /><circle cx="640" cy="170" r="1.8" opacity="0.20" />
      <circle cx="700" cy="110" r="1.4" opacity="0.16" /><circle cx="780" cy="155" r="1.6" opacity="0.18" />
      <circle cx="860" cy="92" r="1.3" opacity="0.15" /><circle cx="940" cy="165" r="1.5" opacity="0.16" />
      <circle cx="1020" cy="105" r="1.3" opacity="0.14" /><circle cx="1100" cy="160" r="1.4" opacity="0.15" />
    </g>

    <path class="line"
      d="M 70 145 C 100 145, 120 230, 160 230 S 250 110, 330 110 S 430 195, 470 195
         S 560 125, 600 125 S 700 165, 740 162 S 840 110, 880 112 S 980 148, 1010 146
         S 1110 140, 1140 140"
      fill="none" stroke="url(#njLine)" stroke-width="2.4" stroke-linecap="round"
      filter="url(#njGlow)" pathLength="1" />

    <g class="nodes" fill="#FFD27A" filter="url(#njGlow)">
      <circle cx="160" cy="230" r="3.2" /><circle cx="470" cy="195" r="2.6" />
      <circle cx="600" cy="125" r="3.0" /><circle cx="880" cy="112" r="3.4" />
      <circle cx="1140" cy="140" r="4.0" />
    </g>
  </svg>
</div>

<style>
  .hero-signal{ width:100%; line-height:0; }
  .hero-signal svg{ width:100%; height:auto; overflow:visible; }
  .line{ stroke-dasharray:1; stroke-dashoffset:1; animation:draw 2.6s cubic-bezier(.4,0,.2,1) .2s forwards; }
  .nodes circle{ opacity:0; animation:node .6s ease-out forwards; }
  .nodes circle:nth-child(1){ animation-delay:.9s; }
  .nodes circle:nth-child(2){ animation-delay:1.5s; }
  .nodes circle:nth-child(3){ animation-delay:1.9s; }
  .nodes circle:nth-child(4){ animation-delay:2.4s; }
  .nodes circle:nth-child(5){ animation-delay:2.9s; }
  @keyframes draw{ to{ stroke-dashoffset:0; } }
  @keyframes node{ to{ opacity:1; } }
  @media (prefers-reduced-motion: reduce){
    .line{ animation:none; stroke-dashoffset:0; }
    .nodes circle{ animation:none; opacity:1; }
  }
</style>
