---
import { SITE, SOCIAL, navItems, CLOSER } from '../consts';
import { TOOLS } from '../data/tools';
import { PUBLICATIONS } from '../data/publications';
import NewsletterForm from './NewsletterForm.astro';
const NAV = navItems();
const year = 2026;
---
<footer class="site-footer">
  <hr class="trace" />
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <p class="closer">{CLOSER}</p>
      <p class="wordmark-foot mono">{SITE.wordmark} · {SITE.descriptor}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      {TOOLS.length > 0 && <a href="/tools">Tools</a>}
      {PUBLICATIONS.length > 0 && <a href="/publications">Publications</a>}
      <a href="/cv">CV</a>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
    </nav>

    <div class="footer-news">
      <NewsletterForm compact />
      <div class="social">
        {SOCIAL.youtube && <a href={SOCIAL.youtube} target="_blank" rel="noopener">YouTube</a>}
        {SOCIAL.linkedin && <a href={SOCIAL.linkedin} target="_blank" rel="noopener">LinkedIn</a>}
      </div>
    </div>
  </div>

  <div class="wrap footer-base">
    <p class="fine">This website and all of its content reflect my personal views only, and do not represent the views or positions of any organisation, employer, association, or affiliation.</p>
    <p class="fine">© {year} {SITE.author} · <a href="/privacy">Privacy</a></p>
  </div>
</footer>

<style>
  .site-footer{ background:var(--ground-deep); margin-top:var(--section-y); }
  .footer-grid{
    display:grid; grid-template-columns:1.4fr 1fr 1.4fr; gap:2.5rem;
    padding-block:var(--section-y) 2rem;
  }
  .closer{ font-family:var(--font-display); font-size:1.5rem; color:var(--ink); max-width:24ch; }
  .wordmark-foot{ color:var(--slate); font-size:0.8125rem; letter-spacing:0.04em; margin-top:1rem; }
  .footer-nav{ display:flex; flex-direction:column; gap:0.6rem; }
  .footer-nav a{
    font-family:var(--font-mono); font-size:0.8125rem; letter-spacing:0.04em; color:var(--slate);
  }
  .footer-nav a:hover{ color:var(--ink); text-decoration:none; }
  .social{ display:flex; gap:1.25rem; margin-top:1.25rem; }
  .social a{ font-family:var(--font-mono); font-size:0.8125rem; color:var(--slate); }
  .footer-base{
    display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap;
    border-top:1px solid var(--hairline); padding-block:1.5rem;
  }
  .footer-base a{ color:var(--slate); text-decoration:underline; }
  .footer-base a:hover{ color:var(--ink); }
  @media (max-width:767px){
    .footer-grid{ grid-template-columns:1fr; gap:2rem; }
  }
</style>
